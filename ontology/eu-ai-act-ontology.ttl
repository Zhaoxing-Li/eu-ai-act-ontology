@prefix euai:    <https://zhaoxing-li.github.io/eu-ai-act-ontology#> .
@prefix airo:    <https://w3id.org/airo#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

#################################################################
#  Ontology metadata + PROV-O pipeline provenance
#################################################################

<https://zhaoxing-li.github.io/eu-ai-act-ontology> a owl:Ontology ;
    dcterms:title "EU AI Act Ontology (proof of concept)" ;
    dcterms:description "A proof-of-concept ontology of the key concepts, actors and obligations of Regulation (EU) 2024/1689 (the EU AI Act), built with an AI-assisted, human-verified pipeline and aligned to the AI Risk Ontology (AIRO)." ;
    dcterms:creator "Zhaoxing Li" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo "0.1.0" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> ;
    prov:wasDerivedFrom <http://data.europa.eu/eli/reg/2024/1689/oj> ;
    prov:generatedAtTime "2026-06-14T12:00:00Z"^^xsd:dateTime ;
    prov:wasGeneratedBy [ a prov:Activity ;
        rdfs:label "AI-assisted ontology engineering pipeline" ;
        rdfs:comment "Fetch + segment (EUR-Lex) -> LLM candidate extraction with verbatim source spans -> human verification gate -> Turtle authoring -> HermiT reasoning -> SPARQL competency-question testing -> provenance back-check." ] ;
    rdfs:comment "Risk is modelled once: HighRiskAISystem is a DEFINED class and membership is INFERRED by a reasoner, not asserted. Obligations are typed by kind and the bearer is attached with euai:imposedOn." .

#################################################################
#  Annotation properties (provenance)
#################################################################

euai:hasArticleReference a owl:AnnotationProperty ;
    rdfs:label "has article reference" ;
    rdfs:comment "Article of Regulation (EU) 2024/1689 that grounds this element." .

euai:hasAnnexReference a owl:AnnotationProperty ;
    rdfs:label "has annex reference" ;
    rdfs:comment "Annex of Regulation (EU) 2024/1689 that grounds this element." .

euai:legalTextSnippet a owl:AnnotationProperty ;
    rdfs:label "legal text snippet" ;
    rdfs:comment "Verbatim excerpt of the source provision (for traceability / hallucination back-check)." .

#################################################################
#  Object properties
#################################################################

euai:operatesInDomain a owl:ObjectProperty ;
    rdfs:subPropertyOf airo:isAppliedWithinDomain ;
    rdfs:label "operates in domain" ;
    rdfs:domain euai:AISystem ;
    rdfs:range euai:AnnexIIIDomain ;
    rdfs:comment "Links an AI system to an Annex III high-risk application area (Article 6(2))." .

euai:hasRiskLevel a owl:ObjectProperty ;
    rdfs:label "has risk level" ;
    rdfs:domain euai:AISystem ;
    rdfs:range euai:RiskLevel ;
    rdfs:comment "Regulatory risk tier of an AI system." .

euai:imposesObligation a owl:ObjectProperty ;
    rdfs:label "imposes obligation" ;
    owl:inverseOf euai:imposedOn ;
    rdfs:comment "A legal source imposes an obligation." .

euai:imposedOn a owl:ObjectProperty ;
    rdfs:label "imposed on" ;
    rdfs:domain euai:Obligation ;
    rdfs:comment "The actor (bearer) on whom an obligation falls. Points to an actor class used as an individual (OWL 2 punning)." .

euai:appliesToSystem a owl:ObjectProperty ;
    rdfs:label "applies to system" ;
    rdfs:domain euai:Obligation ;
    rdfs:comment "The kind of AI system an obligation applies to. Points to a system class used as an individual (OWL 2 punning)." .

euai:prohibitedBy a owl:ObjectProperty ;
    rdfs:label "prohibited by" ;
    rdfs:comment "Links a prohibited practice to the provision that prohibits it." .

#################################################################
#  AI system classes
#################################################################

euai:AISystem a owl:Class ;
    owl:equivalentClass airo:AISystem ;
    rdfs:label "AI system" ;
    skos:definition "A machine-based system designed to operate with varying levels of autonomy, that may exhibit adaptiveness, and that infers from inputs how to generate outputs." ;
        euai:hasArticleReference "Article 3(1)" ;
        euai:legalTextSnippet "‘AI system’ means a machine-based system that is designed to operate with varying levels of autonomy and that may exhibit adaptiveness after deployment, and that, for explicit or implicit objectives, infers, from the inp" ;
        dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> ;
    rdfs:isDefinedBy <https://zhaoxing-li.github.io/eu-ai-act-ontology> .

euai:GeneralPurposeAIModel a owl:Class ;
    rdfs:subClassOf airo:GPAIModel ;
    rdfs:label "General-purpose AI model" ;
    skos:definition "An AI model, including one trained with a large amount of data using self-supervision at scale, that displays significant generality and competence across tasks." ;
        euai:hasArticleReference "Article 3(63)" ;
        euai:legalTextSnippet "‘general-purpose AI model’ means an AI model, including where such an AI model is trained with a large amount of data using self-supervision at scale, that displays significant generality and is capable of competently pe" ;
        dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:LimitedRiskAISystem a owl:Class ;
    rdfs:subClassOf euai:AISystem ;
    rdfs:label "Limited-risk AI system" ;
    skos:definition "An AI system that is not high-risk but is subject to the transparency obligations of Article 50 (e.g. systems interacting with people, or generating synthetic content)." ;
    euai:hasArticleReference "Article 50" .

# --- Article 6(2): the Annex III route is a DEFINED class (membership is inferred) ---
euai:AnnexIIIHighRiskAISystem a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:intersectionOf ( euai:AISystem
            [ a owl:Restriction ;
              owl:onProperty euai:operatesInDomain ;
              owl:someValuesFrom euai:AnnexIIIDomain ] ) ] ;
    rdfs:subClassOf euai:HighRiskAISystem ;
    rdfs:label "Annex III high-risk AI system" ;
    skos:definition "An AI system that operates in one of the high-risk application areas of Annex III (Article 6(2)). Membership is inferred by a reasoner, never asserted on instances." ;
    euai:hasArticleReference "Article 6(2)" ;
    euai:legalTextSnippet "High-risk AI systems pursuant to Article 6(2) are the AI systems listed in any of the following areas: 1. Biometrics, in so far as their use is permitted under relevant Union or national law: (a) remote biometric identif" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> ;
    rdfs:comment "Defined class: AISystem and (operatesInDomain some AnnexIIIDomain). Membership is inferred, not asserted." .

# --- Article 6(1): the product-safety route, modelled as a stub ---
euai:ProductSafetyHighRiskAISystem a owl:Class ;
    rdfs:subClassOf euai:HighRiskAISystem ;
    rdfs:label "Product-safety high-risk AI system" ;
    skos:definition "An AI system that is a safety component of, or is itself, a product covered by the Union harmonisation legislation in Annex I (Article 6(1)). Modelled as a stub: the Annex I product legislation is not modelled here, so this branch has no defining axiom." ;
    euai:hasArticleReference "Article 6(1)" ;
    euai:legalTextSnippet "intended to be used as a safety component of a product, or the AI system is itself a product, covered by the Union harmonisation legislation listed in Annex I; (b) the product whose safety component pursuant to point (a)" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> ;
    rdfs:comment "Article 6(1) product-safety route. Modelled as a stub: it depends on the Annex I product legislation, which is out of scope here." .

# --- High-risk is the UNION of the two routes (Article 6) ---
euai:HighRiskAISystem a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
        owl:unionOf ( euai:AnnexIIIHighRiskAISystem euai:ProductSafetyHighRiskAISystem ) ] ;
    rdfs:subClassOf euai:AISystem ;
    rdfs:label "High-risk AI system" ;
    skos:definition "An AI system that is high-risk under Article 6 — either via the Annex III application areas (Article 6(2)) or the product-safety route (Article 6(1)). Membership is inferred, never asserted on instances." ;
    euai:hasArticleReference "Article 6" ;
    euai:legalTextSnippet "shall be considered to be high-risk where both of the following conditions are fulfilled: (a) the AI system is intended to be used as a safety component of a product, or the AI system is itself a product, covered by the" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> ;
    rdfs:comment "Union of two routes: AnnexIIIHighRiskAISystem (Article 6(2)) and ProductSafetyHighRiskAISystem (Article 6(1))." .

#################################################################
#  Actors  (Act 'operator' == airo:AIOperator)
#################################################################

euai:Actor a owl:Class ;
    owl:equivalentClass airo:AIOperator ;
    rdfs:label "Actor" ;
    euai:hasArticleReference "Article 3(8)" ;
    euai:legalTextSnippet "‘operator’ means a provider, product manufacturer, deployer, authorised representative, importer or distributor; (9) ‘placing on the market’ means the first making available of an AI system or a general-purpose AI model" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> ;
    rdfs:comment "Act's 'operator' == AIRO AIOperator. 'Actor' is the local umbrella for parties bearing obligations." .

euai:Provider a owl:Class ;
    rdfs:subClassOf euai:Actor ;
    rdfs:subClassOf airo:AIProvider ;
    rdfs:label "Provider" ;
    euai:hasArticleReference "Article 3(3)" ;
    euai:legalTextSnippet "‘provider’ means a natural or legal person, public authority, agency or other body that develops an AI system or a general-purpose AI model or that has an AI system or a general-purpose AI model developed and places it o" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:Deployer a owl:Class ;
    rdfs:subClassOf euai:Actor ;
    rdfs:subClassOf airo:AIDeployer ;
    rdfs:label "Deployer" ;
    euai:hasArticleReference "Article 3(4)" ;
    euai:legalTextSnippet "‘deployer’ means a natural or legal person, public authority, agency or other body using an AI system under its authority except where the AI system is used in the course of a personal non-professional activity; (5) ‘aut" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:Importer a owl:Class ;
    rdfs:subClassOf euai:Actor ;
    rdfs:subClassOf airo:AIOperator ;
    rdfs:label "Importer" ;
    euai:hasArticleReference "Article 3(6)" ;
    euai:legalTextSnippet "‘importer’ means a natural or legal person located or established in the Union that places on the market an AI system that bears the name or trademark of a natural or legal person established in a third country; (7) ‘dis" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:Distributor a owl:Class ;
    rdfs:subClassOf euai:Actor ;
    rdfs:subClassOf airo:AIOperator ;
    rdfs:label "Distributor" ;
    euai:hasArticleReference "Article 3(7)" ;
    euai:legalTextSnippet "‘distributor’ means a natural or legal person in the supply chain, other than the provider or the importer, that makes an AI system available on the Union market; (8) ‘operator’ means a provider, product manufacturer, de" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:AuthorisedRepresentative a owl:Class ;
    rdfs:subClassOf euai:Actor ;
    rdfs:subClassOf airo:AIOperator ;
    rdfs:label "Authorised representative" ;
    euai:hasArticleReference "Article 3(5)" ;
    euai:legalTextSnippet "‘authorised representative’ means a natural or legal person located or established in the Union who has received and accepted a written mandate from a provider of an AI system or a general-purpose AI model to, respective" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:MarketSurveillanceAuthority a owl:Class ;
    rdfs:subClassOf airo:Stakeholder ;
    rdfs:label "Market surveillance authority" ;
    euai:hasArticleReference "Article 70" ;
    euai:legalTextSnippet "market surveillance authority for the purposes of this Regulation. Those national competent authorities shall exercise their powers independently, impartially and without bias so as to safeguard the objectivity of their" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> ;
    rdfs:comment "An authority, not an 'operator'. Aligned to airo:Stakeholder rather than airo:AIOperator. Confirm scope." .

#################################################################
#  Risk levels  (individuals, NOT a parallel class tree)
#################################################################

euai:RiskLevel a owl:Class ;
    rdfs:label "Risk level" ;
    skos:definition "A regulatory risk tier of the EU AI Act." .

euai:UnacceptableRisk a euai:RiskLevel ;
    rdfs:label "Unacceptable risk" ;
    euai:hasArticleReference "Article 5" ;
    euai:legalTextSnippet "The following AI practices shall be prohibited: (a) the placing on the market, the putting into service or the use of an AI system that deploys subliminal techniques beyond a person’s consciousness or purposefully manipu" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:HighRisk a euai:RiskLevel ;
    rdfs:label "High risk" ;
    euai:hasArticleReference "Article 6" ;
    euai:legalTextSnippet "high-risk where both of the following conditions are fulfilled: (a) the AI system is intended to be used as a safety component of a product, or the AI system is itself a product, covered by the Union harmonisation legisl" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:LimitedRisk a euai:RiskLevel ;
    rdfs:label "Limited risk" ;
    euai:hasArticleReference "Article 50" ;
    euai:legalTextSnippet "informed that they are interacting with an AI system, unless this is obvious from the point of view of a natural person who is reasonably well-informed, observant and circumspect, taking into account the circumstances an" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> ;
    rdfs:comment "'Limited risk' is the common term for Article 50 transparency-only systems; the term itself is from recitals, not the article body." .

euai:MinimalRisk a euai:RiskLevel ;
    rdfs:label "Minimal risk" ;
    euai:hasArticleReference "Recital 165" ;
    euai:legalTextSnippet "codes of conduct, including related governance mechanisms, intended to foster the voluntary application to AI systems, other than high-risk AI systems, of some or all of the requirements set out in Chapter III, Section 2" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> ;
    rdfs:comment "'Minimal risk' is a recital-level category (voluntary codes of conduct, Art 95). No span in the articles; flagged." .

#################################################################
#  AI practices / prohibited practices  (Article 5)
#################################################################

euai:AIPractice a owl:Class ;
    rdfs:label "AI practice" ;
    skos:definition "A way an AI system is placed on the market, put into service or used." .

euai:ProhibitedPractice a owl:Class ;
    rdfs:subClassOf euai:AIPractice ;
    rdfs:label "Prohibited practice" ;
    skos:definition "An AI practice prohibited under Article 5 of the EU AI Act." ;
    euai:hasArticleReference "Article 5" .

euai:SubliminalManipulation a euai:ProhibitedPractice ;
    rdfs:label "Manipulative or deceptive techniques" ;
    euai:hasRiskLevel euai:UnacceptableRisk ;
    euai:hasArticleReference "Article 5(1)(a)" ;
    euai:legalTextSnippet "deploys subliminal techniques beyond a person’s consciousness or purposefully manipulative or deceptive techniques, with the objective, or the effect of materially distorting the behaviour of a person or a group of perso" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ExploitationOfVulnerabilities a euai:ProhibitedPractice ;
    rdfs:label "Exploitation of vulnerabilities" ;
    euai:hasRiskLevel euai:UnacceptableRisk ;
    euai:hasArticleReference "Article 5(1)(b)" ;
    euai:legalTextSnippet "exploits any of the vulnerabilities of a natural person or a specific group of persons due to their age, disability or a specific social or economic situation, with the objective, or the effect, of materially distorting" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:SocialScoring a euai:ProhibitedPractice ;
    rdfs:label "Social scoring" ;
    euai:hasRiskLevel euai:UnacceptableRisk ;
    euai:hasArticleReference "Article 5(1)(c)" ;
    euai:legalTextSnippet "evaluation or classification of natural persons or groups of persons over a certain period of time based on their social behaviour or known, inferred or predicted personal or personality characteristics, with the social" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:IndividualCrimePrediction a euai:ProhibitedPractice ;
    rdfs:label "Individual criminal-offence risk assessment" ;
    euai:hasRiskLevel euai:UnacceptableRisk ;
    euai:hasArticleReference "Article 5(1)(d)" ;
    euai:legalTextSnippet "risk assessments of natural persons in order to assess or predict the risk of a natural person committing a criminal offence, based solely on the profiling of a natural person or on assessing their personality traits and" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:FacialImageScraping a euai:ProhibitedPractice ;
    rdfs:label "Untargeted facial-image scraping" ;
    euai:hasRiskLevel euai:UnacceptableRisk ;
    euai:hasArticleReference "Article 5(1)(e)" ;
    euai:legalTextSnippet "create or expand facial recognition databases through the untargeted scraping of facial images from the internet or CCTV footage; (f) the placing on the market, the putting into service for this specific purpose, or the" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:EmotionRecognitionWorkEducation a euai:ProhibitedPractice ;
    rdfs:label "Emotion recognition at work or in education" ;
    euai:hasRiskLevel euai:UnacceptableRisk ;
    euai:hasArticleReference "Article 5(1)(f)" ;
    euai:legalTextSnippet "infer emotions of a natural person in the areas of workplace and education institutions, except where the use of the AI system is intended to be put in place or into the market for medical or safety reasons; (g) the plac" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:BiometricCategorisationSensitive a euai:ProhibitedPractice ;
    rdfs:label "Sensitive biometric categorisation" ;
    euai:hasRiskLevel euai:UnacceptableRisk ;
    euai:hasArticleReference "Article 5(1)(g)" ;
    euai:legalTextSnippet "biometric categorisation systems that categorise individually natural persons based on their biometric data to deduce or infer their race, political opinions, trade union membership, religious or philosophical beliefs, s" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:RealTimeRemoteBiometricID a euai:ProhibitedPractice ;
    rdfs:label "Real-time remote biometric identification for law enforcement" ;
    euai:hasRiskLevel euai:UnacceptableRisk ;
    euai:hasArticleReference "Article 5(1)(h)" ;
    euai:legalTextSnippet "real-time’ remote biometric identification systems in publicly accessible spaces for the purposes of law enforcement, unless and in so far as such use is strictly necessary for one of the following objectives: (i) the ta" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> ;
    rdfs:comment "Conditional prohibition (permitted under narrow exceptions). Modelled as prohibited; the exceptions are out of scope for the PoC." .

#################################################################
#  Annex III high-risk application domains  (individuals)
#################################################################

euai:AnnexIIIDomain a owl:Class ;
    rdfs:subClassOf airo:Domain ;
    rdfs:label "Annex III domain" ;
    skos:definition "A high-risk application area listed in Annex III of the EU AI Act (Article 6(2))." ;
    euai:hasAnnexReference "Annex III" .

euai:Biometrics a euai:AnnexIIIDomain ;
    rdfs:label "Biometrics" ;
    euai:hasAnnexReference "Annex III(1)" ;
    euai:legalTextSnippet "Biometrics, in so far as their use is permitted under relevant Union or national law: (a) remote biometric identification systems. This shall not include AI systems intended to be used for biometric verification the sole" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:CriticalInfrastructure a euai:AnnexIIIDomain ;
    rdfs:label "Critical infrastructure" ;
    euai:hasAnnexReference "Annex III(2)" ;
    euai:legalTextSnippet "Critical infrastructure: AI systems intended to be used as safety components in the management and operation of critical digital infrastructure, road traffic, or in the supply of water, gas, heating or electricity. 3. Ed" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:EducationAndVocationalTraining a euai:AnnexIIIDomain ;
    rdfs:label "Education and vocational training" ;
    euai:hasAnnexReference "Annex III(3)" ;
    euai:legalTextSnippet "Education and vocational training: (a) AI systems intended to be used to determine access or admission or to assign natural persons to educational and vocational training institutions at all levels; (b) AI systems intend" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:EmploymentAndWorkerManagement a euai:AnnexIIIDomain ;
    rdfs:label "Employment and worker management" ;
    euai:hasAnnexReference "Annex III(4)" ;
    euai:legalTextSnippet "Employment, workers’ management and access to self-employment: (a) AI systems intended to be used for the recruitment or selection of natural persons, in particular to place targeted job advertisements, to analyse and fi" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:EssentialServices a euai:AnnexIIIDomain ;
    rdfs:label "Access to essential services" ;
    euai:hasAnnexReference "Annex III(5)" ;
    euai:legalTextSnippet "essential private services and essential public services and benefits: (a) AI systems intended to be used by public authorities or on behalf of public authorities to evaluate the eligibility of natural persons for essent" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:LawEnforcement a euai:AnnexIIIDomain ;
    rdfs:label "Law enforcement" ;
    euai:hasAnnexReference "Annex III(6)" ;
    euai:legalTextSnippet "Law enforcement, in so far as their use is permitted under relevant Union or national law: (a) AI systems intended to be used by or on behalf of law enforcement authorities, or by Union institutions, bodies, offices or a" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:MigrationAsylumBorderControl a euai:AnnexIIIDomain ;
    rdfs:label "Migration, asylum and border control" ;
    euai:hasAnnexReference "Annex III(7)" ;
    euai:legalTextSnippet "Migration, asylum and border control management, in so far as their use is permitted under relevant Union or national law: (a) AI systems intended to be used by or on behalf of competent public authorities or by Union in" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:AdministrationOfJusticeAndDemocracy a euai:AnnexIIIDomain ;
    rdfs:label "Administration of justice and democratic processes" ;
    euai:hasAnnexReference "Annex III(8)" ;
    euai:legalTextSnippet "Administration of justice and democratic processes: (a) AI systems intended to be used by a judicial authority or on their behalf to assist a judicial authority in researching and interpreting facts and the law and in ap" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

#################################################################
#  Obligations  (typed by KIND; bearer attached with euai:imposedOn)
#################################################################

euai:Obligation a owl:Class ;
    rdfs:label "Obligation" ;
    skos:definition "A duty imposed by the EU AI Act on an actor in respect of an AI system." .

euai:TransparencyObligation a owl:Class ;
    rdfs:subClassOf euai:Obligation ;
    rdfs:label "Transparency obligation" ;
    skos:definition "Duty to disclose information about an AI system or its outputs." ;
    euai:hasArticleReference "Articles 13, 50" .

euai:RiskManagementObligation a owl:Class ;
    rdfs:subClassOf euai:Obligation ;
    rdfs:label "RiskManagement obligation" ;
    skos:definition "Duty to establish a risk management system (Article 9)." ;
    euai:hasArticleReference "Article 9" .

euai:DataGovernanceObligation a owl:Class ;
    rdfs:subClassOf euai:Obligation ;
    rdfs:label "DataGovernance obligation" ;
    skos:definition "Duty over training, validation and testing data quality and governance (Article 10)." ;
    euai:hasArticleReference "Article 10" .

euai:TechnicalDocumentationObligation a owl:Class ;
    rdfs:subClassOf euai:Obligation ;
    rdfs:label "TechnicalDocumentation obligation" ;
    skos:definition "Duty to draw up and keep technical documentation (Article 11)." ;
    euai:hasArticleReference "Article 11" .

euai:LoggingObligation a owl:Class ;
    rdfs:subClassOf euai:Obligation ;
    rdfs:label "Logging obligation" ;
    skos:definition "Duty to enable automatic recording of events / logs (Article 12)." ;
    euai:hasArticleReference "Article 12" .

euai:HumanOversightObligation a owl:Class ;
    rdfs:subClassOf euai:Obligation ;
    rdfs:label "HumanOversight obligation" ;
    skos:definition "Duty to enable or ensure effective human oversight (Articles 14, 26)." ;
    euai:hasArticleReference "Articles 14, 26" .

euai:PostMarketMonitoringObligation a owl:Class ;
    rdfs:subClassOf euai:Obligation ;
    rdfs:label "PostMarketMonitoring obligation" ;
    skos:definition "Duty to monitor systems after they are placed on the market (Article 72)." ;
    euai:hasArticleReference "Article 72" .

euai:AccuracyRobustnessObligation a owl:Class ;
    rdfs:subClassOf euai:Obligation ;
    rdfs:label "AccuracyRobustness obligation" ;
    skos:definition "Duty to achieve appropriate accuracy, robustness and cybersecurity (Article 15)." ;
    euai:hasArticleReference "Article 15" .

euai:ConformityVerificationObligation a owl:Class ;
    rdfs:subClassOf euai:Obligation ;
    rdfs:label "ConformityVerification obligation" ;
    skos:definition "Duty of importers and distributors to verify a high-risk system's conformity, CE marking and documentation before placing it on / making it available on the market." ;
    euai:hasArticleReference "Articles 23, 24" .

euai:RepresentationObligation a owl:Class ;
    rdfs:subClassOf euai:Obligation ;
    rdfs:label "Representation obligation" ;
    skos:definition "Duty of an authorised representative to perform the verification and cooperation tasks set out in the provider's written mandate." ;
    euai:hasArticleReference "Article 22" .

euai:ob_RiskManagement a euai:RiskManagementObligation ;
    rdfs:label "Risk management obligation" ;
    euai:imposedOn euai:Provider ;
    euai:appliesToSystem euai:HighRiskAISystem ;
    euai:hasArticleReference "Article 9" ;
    euai:legalTextSnippet "risk management system shall be established, implemented, documented and maintained in relation to high-risk AI systems. 2. The risk management system shall be understood as a continuous iterative process planned and run" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_DataGovernance a euai:DataGovernanceObligation ;
    rdfs:label "Data and data governance obligation" ;
    euai:imposedOn euai:Provider ;
    euai:appliesToSystem euai:HighRiskAISystem ;
    euai:hasArticleReference "Article 10" ;
    euai:legalTextSnippet "shall be subject to data governance and management practices appropriate for the intended purpose of the high-risk AI system. Those practices shall concern in particular: (a) the relevant design choices; (b) data collect" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_TechnicalDocumentation a euai:TechnicalDocumentationObligation ;
    rdfs:label "Technical documentation obligation" ;
    euai:imposedOn euai:Provider ;
    euai:appliesToSystem euai:HighRiskAISystem ;
    euai:hasArticleReference "Article 11" ;
    euai:legalTextSnippet "technical documentation of a high-risk AI system shall be drawn up before that system is placed on the market or put into service and shall be kept up-to date. The technical documentation shall be drawn up in such a way" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_RecordKeeping a euai:LoggingObligation ;
    rdfs:label "Record-keeping (logging) obligation" ;
    euai:imposedOn euai:Provider ;
    euai:appliesToSystem euai:HighRiskAISystem ;
    euai:hasArticleReference "Article 12" ;
    euai:legalTextSnippet "technically allow for the automatic recording of events (logs) over the lifetime of the system. 2. In order to ensure a level of traceability of the functioning of a high-risk AI system that is appropriate to the intende" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_ProviderTransparency a euai:TransparencyObligation ;
    rdfs:label "Transparency and provision of information to deployers" ;
    euai:imposedOn euai:Provider ;
    euai:appliesToSystem euai:HighRiskAISystem ;
    euai:hasArticleReference "Article 13" ;
    euai:legalTextSnippet "designed and developed in such a way as to ensure that their operation is sufficiently transparent to enable deployers to interpret a system’s output and use it appropriately. An appropriate type and degree of transparen" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_HumanOversightDesign a euai:HumanOversightObligation ;
    rdfs:label "Human oversight (design) obligation" ;
    euai:imposedOn euai:Provider ;
    euai:appliesToSystem euai:HighRiskAISystem ;
    euai:hasArticleReference "Article 14" ;
    euai:legalTextSnippet "designed and developed in such a way, including with appropriate human-machine interface tools, that they can be effectively overseen by natural persons during the period in which they are in use. 2. Human oversight shal" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_AccuracyRobustness a euai:AccuracyRobustnessObligation ;
    rdfs:label "Accuracy, robustness and cybersecurity obligation" ;
    euai:imposedOn euai:Provider ;
    euai:appliesToSystem euai:HighRiskAISystem ;
    euai:hasArticleReference "Article 15" ;
    euai:legalTextSnippet "achieve an appropriate level of accuracy, robustness, and cybersecurity, and that they perform consistently in those respects throughout their lifecycle. 2. To address the technical aspects of how to measure the appropri" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_PostMarketMonitoring a euai:PostMarketMonitoringObligation ;
    rdfs:label "Post-market monitoring obligation" ;
    euai:imposedOn euai:Provider ;
    euai:appliesToSystem euai:HighRiskAISystem ;
    euai:hasArticleReference "Article 72" ;
    euai:legalTextSnippet "establish and document a post-market monitoring system in a manner that is proportionate to the nature of the AI technologies and the risks of the high-risk AI system. 2. The post-market monitoring system shall actively" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_DeployerHumanOversight a euai:HumanOversightObligation ;
    rdfs:label "Deployer human oversight obligation" ;
    euai:imposedOn euai:Deployer ;
    euai:appliesToSystem euai:HighRiskAISystem ;
    euai:hasArticleReference "Article 26" ;
    euai:legalTextSnippet "assign human oversight to natural persons who have the necessary competence, training and authority, as well as the necessary support. 3. The obligations set out in paragraphs 1 and 2, are without prejudice to other depl" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_ImporterConformity a euai:ConformityVerificationObligation ;
    rdfs:label "Importer conformity verification" ;
    euai:imposedOn euai:Importer ;
    euai:appliesToSystem euai:HighRiskAISystem ;
    euai:hasArticleReference "Article 23" ;
    euai:legalTextSnippet "Before placing a high-risk AI system on the market, importers shall ensure that the system is in conformity with this Regulation by verifying that: (a) the relevant conformity assessment procedure referred to in Article" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_DistributorVerification a euai:ConformityVerificationObligation ;
    rdfs:label "Distributor verification" ;
    euai:imposedOn euai:Distributor ;
    euai:appliesToSystem euai:HighRiskAISystem ;
    euai:hasArticleReference "Article 24" ;
    euai:legalTextSnippet "Before making a high-risk AI system available on the market, distributors shall verify that it bears the required CE marking, that it is accompanied by a copy of the EU declaration of conformity referred to in Article 47" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_AuthRepTasks a euai:RepresentationObligation ;
    rdfs:label "Authorised representative mandate tasks" ;
    euai:imposedOn euai:AuthorisedRepresentative ;
    euai:appliesToSystem euai:HighRiskAISystem ;
    euai:hasArticleReference "Article 22" ;
    euai:legalTextSnippet "The authorised representative shall perform the tasks specified in the mandate received from the provider. It shall provide a copy of the mandate to the market surveillance authorities upon request, in one of the officia" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_AIInteractionDisclosure a euai:TransparencyObligation ;
    rdfs:label "AI interaction disclosure" ;
    euai:imposedOn euai:Provider ;
    euai:appliesToSystem euai:LimitedRiskAISystem ;
    euai:hasArticleReference "Article 50(1)" ;
    euai:legalTextSnippet "informed that they are interacting with an AI system, unless this is obvious from the point of view of a natural person who is reasonably well-informed, observant and circumspect, taking into account the circumstances an" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_SyntheticContentMarking a euai:TransparencyObligation ;
    rdfs:label "Synthetic content marking" ;
    euai:imposedOn euai:Provider ;
    euai:appliesToSystem euai:LimitedRiskAISystem ;
    euai:hasArticleReference "Article 50(2)" ;
    euai:legalTextSnippet "outputs of the AI system are marked in a machine-readable format and detectable as artificially generated or manipulated. Providers shall ensure their technical solutions are effective, interoperable, robust and reliable" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> .

euai:ob_DeepfakeDisclosure a euai:TransparencyObligation ;
    rdfs:label "Deep fake disclosure" ;
    euai:imposedOn euai:Deployer ;
    euai:appliesToSystem euai:LimitedRiskAISystem ;
    euai:hasArticleReference "Article 50(4)" ;
    euai:legalTextSnippet "constituting a deep fake, shall disclose that the content has been artificially generated or manipulated. This obligation shall not apply where the use is authorised by law to detect, prevent, investigate or prosecute cr" ;
    dcterms:source <http://data.europa.eu/eli/reg/2024/1689/oj> ;
    rdfs:comment "Conditional (exceptions for law-enforcement and artistic works). Modelled as a transparency obligation; exceptions out of scope for the PoC." .

